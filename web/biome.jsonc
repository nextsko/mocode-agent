{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    // external code
    "includes": [
      "!src/components/ai-elements",
      "!src/components/ui",
      "!src/lib/api",
      "!**/dist",
    ],
  },
  "formatter": {
    // Disable Biome formatting while we continue using Prettier.
    "enabled": false,
  },
  // TODO: some rules can be enabled later when the development is more mature
  "linter": {
    "rules": {
      "correctness": {
        // View Transitions API uses ::view-transition-old(root) which linter doesn't recognize
        "noUnknownTypeSelector": "off",
        // Some forwardRef-wrapped React 19 components are misdetected as plain
        // functions in the current Biome rule set used here.
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "off",
      },
      "suspicious": {
        // Middleware pattern often requires async without await
        "useAwait": "off",
        // Existing UI lists intentionally render stable append-only arrays and
        // forwardRef remains in use until the React 19 migration is completed.
        "noArrayIndexKey": "off",
        "noReactForwardRef": "off",
      },
      "performance": {},
      "complexity": {
        // TODO: refactor complex functions later
        "noExcessiveCognitiveComplexity": "off",
      },
      "nursery": {
        "useSortedClasses": "off",
        "noLeakedRender": "off",
      },
      "style": "off",
    },
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "off",
        "useSortedAttributes": "off",
        "useSortedProperties": "off",
      },
    },
  },
  "overrides": [
    {
      "includes": ["src/lib/api/**/*", "openapi.json"],
      "linter": {
        "enabled": false,
      },
      "formatter": {
        "enabled": false,
      },
    },
    {
      "includes": ["biome.jsonc", "index.html"],
      "formatter": {
        "enabled": false,
      },
    },
  ],
}
